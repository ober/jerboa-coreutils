;; Sscheme_script(who, argc, argv): command-line = (who argv[1] ... argv[argc-1]).
;; argv[0] is the command name — passed via _CU_CMD env since Chez drops it.
;; (cdr (command-line)) = user args (argv[1..]).
(let* ((cmd-env (getenv "_CU_CMD"))
       (name (path-basename (or cmd-env (car (command-line)))))
       (args (cdr (command-line)))
       (entry (assoc name *dispatch*)))
  (if entry
    (apply (cdr entry) args)
    (begin
      (display (string-append name ": unknown command\n") (current-error-port))
      (exit 127))))
