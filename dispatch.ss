;; Extract basename from a path string
(define (path-basename p)
  (let lp ((i (- (string-length p) 1)))
    (cond
      ((< i 0) p)
      ((char=? (string-ref p i) #\/) (substring p (+ i 1) (string-length p)))
      (else (lp (- i 1))))))

(define *dispatch*
  (list
    (cons "true" true-main)
    (cons "false" false-main)
    (cons "yes" yes-main)
    (cons "echo" echo-main)
    (cons "printenv" printenv-main)
    (cons "sleep" sleep-main)
    (cons "whoami" whoami-main)
    (cons "logname" logname-main)
    (cons "pwd" pwd-main)
    (cons "basename" basename-main)
    (cons "dirname" dirname-main)
    (cons "link" link-main)
    (cons "unlink" unlink-main)
    (cons "hostname" hostname-main)
    (cons "nproc" nproc-main)
    (cons "tty" tty-main)
    (cons "sync" sync-main)
    (cons "cat" cat-main)
    (cons "head" head-main)
    (cons "tail" tail-main)
    (cons "wc" wc-main)
    (cons "tee" tee-main)
    (cons "tac" tac-main)
